{
  "name": "erp-electron",
  "private": true,
  "version": "1.0.0",
  "description": "ERP System",
  "author": "ERP Team",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder --dir",
    "build:exe": "tsc && vite build && electron-packager . \"ERP System\" --platform=win32 --arch=x64 --out=release --overwrite --prune --ignore=\"/(src|electron|tsconfig\\.json|vite\\.config\\.ts|\\.eslintrc\\.cjs|\\.git)/\"",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@tanstack/react-query": "^5.100.7",
    "axios": "^1.15.2",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.100.7",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.erp.electron",
    "productName": "ERP System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "dir",
      "signingHashAlgorithms": null,
      "sign": null
    }
  }
}
