# ──────────────────────────────────────────────────────────────
# API URL is set automatically based on the build mode:
#
#   npm run dev          → .env.development  (local backend)
#   npm run build / exe  → .env.production   (live backend)
#
# Override here only if you need a custom URL for both modes.
# ──────────────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:3070/api/v1
